local function CreateSlider(parent, name, min, max, default, step, callback, layoutOrder)
    local holder = Create("Frame", { Name = name, Size = UDim2.new(1, 0, 0, 50), BackgroundColor3 = Color3.fromRGB(22, 22, 22), BorderSizePixel = 0, LayoutOrder = layoutOrder or 0, Parent = parent })
    AddCorner(holder, 7)
    local valueDisplay = Create("TextLabel", { Size = UDim2.new(0, 60, 0, 20), Position = UDim2.new(1, -74, 0, 4), BackgroundTransparency = 1, Text = tostring(default), TextColor3 = Color3.fromRGB(140, 140, 140), TextSize = 12, Font = Enum.Font.GothamMedium, TextXAlignment = Enum.TextXAlignment.Right, Parent = holder })
    Create("TextLabel", { Size = UDim2.new(1, -80, 0, 20), Position = UDim2.new(0, 14, 0, 4), BackgroundTransparency = 1, Text = name, TextColor3 = Color3.fromRGB(190, 190, 190), TextSize = 13, Font = Enum.Font.GothamMedium, TextXAlignment = Enum.TextXAlignment.Left, Parent = holder })
    local sliderBg = Create("Frame", { Size = UDim2.new(1, -28, 0, 6), Position = UDim2.new(0, 14, 0, 32), BackgroundColor3 = Color3.fromRGB(35, 35, 35), BorderSizePixel = 0, Parent = holder })
    AddCorner(sliderBg, 3)
    local pct = math.clamp((default - min) / (max - min), 0, 1)
    local sliderFill = Create("Frame", { Size = UDim2.new(pct, 0, 1, 0), BackgroundColor3 = Color3.fromRGB(255, 255, 255), BorderSizePixel = 0, Parent = sliderBg })
    AddCorner(sliderFill, 3)
    local sknob = Create("Frame", { Size = UDim2.new(0, 12, 0, 12), Position = UDim2.new(pct, -6, 0.5, -6), BackgroundColor3 = Color3.fromRGB(255, 255, 255), BorderSizePixel = 0, ZIndex = 3, Parent = sliderBg })
    AddCorner(sknob, 6)
    local dragging = false
    local currentVal = default
    local interactBtn = Create("TextButton", { Size = UDim2.new(1, 0, 0, 20), Position = UDim2.new(0, 0, 0, 26), BackgroundTransparency = 1, Text = "", Parent = holder })
    local function Update(input)
        local relX = input.Position.X - sliderBg.AbsolutePosition.X
        local pctNew = math.clamp(relX / sliderBg.AbsoluteSize.X, 0, 1)
        local raw = min + pctNew * (max - min)
        local snapped = math.clamp(math.floor(raw / step + 0.5) * step, min, max)
        currentVal = snapped
        local displayPct = (snapped - min) / (max - min)
        sliderFill.Size = UDim2.new(displayPct, 0, 1, 0)
        sknob.Position = UDim2.new(displayPct, -6, 0.5, -6)
        valueDisplay.Text = step < 1 and string.format("%.2f", snapped) or tostring(math.floor(snapped))
        callback(snapped)
    end
    interactBtn.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; Update(input) end end)
    interactBtn.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false; QueueAutoSave() end end)
    sliderBg.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; Update(input) end end)
    UserInputService.InputChanged:Connect(function(input) if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then Update(input) end end)
    UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 and dragging then dragging = false; QueueAutoSave() end end)
    return { Set = function(val) currentVal = val; local dp = (val - min) / (max - min); sliderFill.Size = UDim2.new(dp, 0, 1, 0); sknob.Position = UDim2.new(dp, -6, 0.5, -6); valueDisplay.Text = step < 1 and string.format("%.2f", val) or tostring(math.floor(val)); callback(val) end, Get = function() return currentVal end }
end

