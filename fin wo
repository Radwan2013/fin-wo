local function CreateKeyPicker(parent, name, currentKey, callback, layoutOrder)
    local listening = false
    local holder = Create("Frame", { Name = name, Size = UDim2.new(1, 0, 0, 36), BackgroundColor3 = Color3.fromRGB(22, 22, 22), BorderSizePixel = 0, LayoutOrder = layoutOrder or 0, Parent = parent })
    AddCorner(holder, 7)
    Create("TextLabel", { Size = UDim2.new(0.55, -10, 1, 0), Position = UDim2.new(0, 14, 0, 0), BackgroundTransparency = 1, Text = name, TextColor3 = Color3.fromRGB(190, 190, 190), TextSize = 13, Font = Enum.Font.GothamMedium, TextXAlignment = Enum.TextXAlignment.Left, Parent = holder })
    local keyBtn = Create("TextButton", { Size = UDim2.new(0.4, -10, 0, 26), Position = UDim2.new(0.6, 0, 0.5, -13), BackgroundColor3 = Color3.fromRGB(30, 30, 30), BorderSizePixel = 0, Text = GetKeyDisplayName(currentKey), TextColor3 = Color3.fromRGB(160, 160, 160), TextSize = 12, Font = Enum.Font.GothamMedium, AutoButtonColor = false, Parent = holder })
    AddCorner(keyBtn, 6)
    local conn1
    local function StopListening() listening = false; Tween(keyBtn, {BackgroundColor3 = Color3.fromRGB(30, 30, 30)}, 0.2); if conn1 then conn1:Disconnect(); conn1 = nil end end
    local function StartListening()
        listening = true; keyBtn.Text = "..."; Tween(keyBtn, {BackgroundColor3 = Color3.fromRGB(50, 50, 50)}, 0.2)
        conn1 = UserInputService.InputBegan:Connect(function(input)
            if not listening then return end
            if input.UserInputType == Enum.UserInputType.Keyboard then
                if input.KeyCode == Enum.KeyCode.Escape then keyBtn.Text = GetKeyDisplayName(currentKey); StopListening(); return end
                currentKey = input.KeyCode; keyBtn.Text = GetKeyDisplayName(currentKey); callback(currentKey); QueueAutoSave(); StopListening(); return
            end
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.MouseButton2 or input.UserInputType == Enum.UserInputType.MouseButton3 then
                currentKey = input.UserInputType; keyBtn.Text = GetKeyDisplayName(currentKey); callback(currentKey); QueueAutoSave(); StopListening(); return
            end
        end)
    end
    keyBtn.MouseButton1Click:Connect(function() if listening then StopListening(); keyBtn.Text = GetKeyDisplayName(currentKey) else StartListening() end end)
    return { Set = function(val) currentKey = val; keyBtn.Text = GetKeyDisplayName(val); callback(val) end, Get = function() return currentKey end }
end

