-- ==================== HUMANIZED AIM ====================

local function HumanizedMouseMove(deltaX, deltaY, smoothness, sensitivity)
    local jitterX = (math.random() - 0.5) * HumanAim.MicroJitter
    local jitterY = (math.random() - 0.5) * HumanAim.MicroJitter
    local distance = math.sqrt(deltaX * deltaX + deltaY * deltaY)
    local speedFactor = 1
    if HumanAim.AccelerationCurve and distance > 0 then
        local normalizedDist = math.clamp(distance / 500, 0, 1)
        speedFactor = 1 - (1 - normalizedDist) * (1 - normalizedDist) * 0.3
    end
    local overshootX, overshootY = 0, 0
    if math.random() < HumanAim.Overshoot then
        overshootX = deltaX * (math.random() * 0.15 + 0.02)
        overshootY = deltaY * (math.random() * 0.15 + 0.02)
    end
    local finalX = ((deltaX + overshootX) / math.max(smoothness, 0.1)) * sensitivity * speedFactor + jitterX
    local finalY = ((deltaY + overshootY) / math.max(smoothness, 0.1)) * sensitivity * speedFactor + jitterY
    finalX = math.clamp(finalX, -150, 150)
    finalY = math.clamp(finalY, -150, 150)
    mousemoverel(finalX, finalY)
end

-- ==================== AIMBOT FUNCTIONS ====================

local function IsAlive(player)
    if not player then return false end
    local char = player.Character
    if not char then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return false end
    return hum.Health > Config.HealthThreshold
end

local function IsVisible(part)
    if not part then return false end
    local origin = Camera.CFrame.Position
    local direction = (part.Position - origin)
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {LocalPlayer.Character, Camera}
    local result = workspace:Raycast(origin, direction, params)
    if not result then return true end
    return result.Instance:IsDescendantOf(part.Parent)
end

local function GetTargetPart(character)
    local part = character:FindFirstChild(Config.TargetPart)
    if part then return part end
    return character:FindFirstChild("Head") or character:FindFirstChild("HumanoidRootPart")
end

local function GetClosestPlayer()
    local closest, closestDist = nil, Config.FOVRadius
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        if Config.TeamCheck and plr.Team and LocalPlayer.Team and plr.Team == LocalPlayer.Team then continue end
        if Config.AliveCheck and not IsAlive(plr) then continue end
        local char = plr.Character; if not char then continue end
        local part = GetTargetPart(char); if not part then continue end
        if Config.WallCheck and not IsVisible(part) then continue end
        local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
        if not onScreen then continue end
        local dist = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
        if dist < closestDist then closestDist = dist; closest = plr end
    end
    return closest
end

local function GetClosestPlayerSuperSticky()
    local closest, closestDist = nil, Config.FOVRadius * Config.SuperStickyFOVMultiplier
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        if Config.TeamCheck and plr.Team and LocalPlayer.Team and plr.Team == LocalPlayer.Team then continue end
        if Config.AliveCheck and not IsAlive(plr) then continue end
        local char = plr.Character; if not char then continue end
        local part = GetTargetPart(char); if not part then continue end
        if Config.WallCheck and not IsVisible(part) then continue end
        local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
        if not onScreen then continue end
        local dist = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
        if dist < closestDist then closestDist = dist; closest = plr end
    end
    return closest
end

local function GetClosestPlayerForTriggerbot()
    local closest, closestDist = nil, Config.FOVRadius
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        if Config.TeamCheck and plr.Team and LocalPlayer.Team and plr.Team == LocalPlayer.Team then continue end
        if Config.AliveCheck and not IsAlive(plr) then continue end
        local char = plr.Character; if not char then continue end
        local part = GetTargetPart(char); if not part then continue end
        if Config.TriggerBotWallCheck and not IsVisible(part) then continue end
        local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
        if not onScreen then continue end
        local dist = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
        if dist < closestDist then closestDist = dist; closest = plr end
    end
    return closest
end

local function InputMatchesAimKey(input)
    local aimKey = Config.AimKey
    if typeof(aimKey) == "EnumItem" then
        if aimKey.EnumType == Enum.UserInputType then return input.UserInputType == aimKey
        elseif aimKey.EnumType == Enum.KeyCode then return input.KeyCode == aimKey end
    end
    return false
end

