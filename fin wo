local function DeepCopy(t)
    local copy = {}
    for k, v in pairs(t) do
        if type(v) == "table" then copy[k] = DeepCopy(v) else copy[k] = v end
    end
    return copy
end

local function SerializeConfig(cfg)
    local data = {}
    for k, v in pairs(cfg) do
        if typeof(v) == "EnumItem" then
            data[k] = {_enumType = "EnumItem", _enumPath = tostring(v)}
        else
            data[k] = v
        end
    end
    return data
end

local function ResolveEnumFromPath(path)
    local parts = string.split(path, ".")
    if #parts == 3 and parts[1] == "Enum" then
        local success, result = pcall(function() return Enum[parts[2]][parts[3]] end)
        if success then return result end
    end
    return nil
end

local function DeserializeConfig(data, defaults)
    local cfg = DeepCopy(defaults)
    for k, v in pairs(data) do
        if type(v) == "table" and v._enumType == "EnumItem" then
            local resolved = ResolveEnumFromPath(v._enumPath)
            if resolved then cfg[k] = resolved end
        elseif defaults[k] ~= nil then
            cfg[k] = v
        end
    end
    return cfg
end

local function SaveConfig(cfg)
    pcall(function()
        local serialized = SerializeConfig(cfg)
        local json = HttpService:JSONEncode(serialized)
        writefile(SaveFileName, json)
    end)
end

local function LoadConfig(defaults)
    local success, result = pcall(function()
        if isfile(SaveFileName) then
            local json = readfile(SaveFileName)
            local data = HttpService:JSONDecode(json)
            return DeserializeConfig(data, defaults)
        end
        return nil
    end)
    if success and result then return result end
    return DeepCopy(defaults)
end

